# Create an OpenAI API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Drive uploads need write-capable credentials.
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Preferred: rename its JSON key to google-service-account.json and put it in the repo root.
# Optional override if the JSON key lives somewhere else:
GOOGLE_APPLICATION_CREDENTIALS=

# Or copy client_email and private_key from the service account JSON key:
# https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
